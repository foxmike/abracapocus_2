# Copy to .env and customize for your environment
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_BACKEND=codex_cli
BACKEND_OVERRIDE=
ROUTING_MODE=manual
REQUIRE_VERIFICATION=true
REQUIRE_REVIEWER=true
PROJECT_NAME=abracapocus_2
ABRACAPOCUS_WORKING_ROOT=
#
# Optional comma-separated OpenRouter model names to prefer in aider_cli routing,
# e.g. OPENROUTER_PREFERRED_MODELS=openrouter/qwen/qwen3-coder-next,openrouter/deepseek/deepseek-v3.2
OPENROUTER_PREFERRED_MODELS=
DEEP_AGENT_MODEL=gpt-4o-mini
DEEP_AGENT_MOCK_MODE=true
DEEP_AGENT_TIMEOUT_SECONDS=60
# Allow runs directly from main/master when true. Keep false for branch protection.
ABRACAPOCUS_ALLOW_MAIN=false
# Base branch used for merge/abandon operations and run-branch lifecycle.
ABRACAPOCUS_BASE_BRANCH=main
RETRY_TIER_1=2
RETRY_TIER_2=1
RETRY_TIER_3=1
RETRY_DELAY_SECONDS=2
# Provide LangChain + provider credentials when ready
OPENAI_API_KEY=
# Required for Claude Code CLI (`claude`) authentication.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
